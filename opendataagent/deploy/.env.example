OPENDATAAGENT_VERSION=1.2.0
COMPOSE_PROJECT_NAME=opendataagent

OPENDATAAGENT_WEB_PORT=18080
OPENDATAAGENT_SERVER_PORT=18900
OPENDATAAGENT_MYSQL_PORT=13306
# 在线源码部署默认指向仓库根 skills/
# 离线部署包会自动改写为 ../shared-skills
OPENDATAAGENT_SHARED_SKILLS_PATH=../../skills

OPENDATAAGENT_ADMIN_TOKEN=change-me

MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=opendataagent
MYSQL_USER=opendataagent
MYSQL_PASSWORD=opendataagent123

ODA_STORE_DRIVER=mysql
ODA_MYSQL_DATABASE=opendataagent
SESSION_MYSQL_DATABASE=opendataagent

# 可选，留空表示通过模型设置页面维护
# ODA_ADMIN_TOKEN=
